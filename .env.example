# Copy this file to .env.local and fill in your key to enable the AI tutor.
# On Vercel, set these in Project Settings → Environment Variables instead.
#
# Without ANTHROPIC_API_KEY the site still works — the "Ask the AI tutor"
# box simply reports that the feature isn't configured.

# Your Anthropic API key (https://console.anthropic.com/).
ANTHROPIC_API_KEY=

# Optional: override the model. Defaults to claude-opus-4-8.
# Set to claude-haiku-4-5 for ~5× cheaper, faster answers.
# EXPLAIN_MODEL=claude-opus-4-8
